# Server Configuration
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/eexams

# JWT Secret (generate a strong random string)
JWT_SECRET=your_jwt_secret_key_here

# Google OAuth Configuration
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=192720000772-1qkm1i0lmg52b17vaslf0gm56lll3p0m.apps.googleusercontent.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Super Admin Configuration (comma-separated emails)
SUPER_ADMIN_EMAILS=superadmin@testfyrwanda.com

# Groq AI Configuration (REQUIRED - Used for AI grading and question extraction)
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Legacy Gemini AI Configuration (Optional fallback - not currently used)
# GEMINI_API_KEY=your_gemini_api_key_here

# SendGrid Configuration (REQUIRED for password reset emails)
# Get your API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@eexams.com

# Client URL (for password reset links)
CLIENT_URL=http://localhost:5173

# Cloudinary Configuration (REQUIRED for question image uploads)
# Get these from: https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
